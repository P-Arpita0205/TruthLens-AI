# =============================================================
# TruthLens AI — Backend Environment Variables Template
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit the real .env file!
# =============================================================

PORT=5000

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email / SMTP Configuration for OTP (use a Gmail App Password)
# How to create an App Password: https://support.google.com/accounts/answer/185833
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here

# ── Tier 2 Fallback: Sightengine Deepfake Detection API (~90%+ accuracy) ──────
# Activates automatically when Gemini VLM fails, is rate-limited, or returns
# an inconclusive result. Trained on the DFDC dataset for forensic-grade detection.
# Get free API keys at: https://sightengine.com/
# Leave blank to skip Sightengine and fall back directly to local CNN/OpenCV signals.
SIGHTENGINE_API_USER=your_sightengine_api_user
SIGHTENGINE_API_SECRET=your_sightengine_api_secret
