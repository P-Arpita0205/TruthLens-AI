# =============================================================
# TruthLens AI — Backend Environment Variables Template
# Copy this file to .env and fill in your actual values.
# ⚠️  NEVER commit the real .env file!
# =============================================================

PORT=5000

# Google Gemini API Key
# Get yours at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Email / SMTP Configuration for OTP (use a Gmail App Password)
# How to create an App Password: https://support.google.com/accounts/answer/185833
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_gmail_app_password_here
